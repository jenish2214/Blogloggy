# Copy to .env.docker for docker compose (gitignored)
# cp .env.docker.example .env.docker

# Site (browser + OAuth redirects when self-hosting)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (required for real sign-in; placeholders allow demo build)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# CORS for Express + Python services
CORS_ORIGINS=http://localhost:3000

# Optional market data keys (backend + Next API routes)
MASSIVE_API_KEY=
FINNHUB_API_KEY=
NEXT_PUBLIC_FINNHUB_API_KEY=
ALPHAVANTAGE_API_KEY=
NEWS_API_KEY=
