# QuantDesk — Required environment variables
# Copy to .env.local for local dev
# Set all of these in your Vercel project dashboard under Settings > Environment Variables

# Supabase (get from https://supabase.com/dashboard/project/<id>/settings/api)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Your deployed URL (optional on Vercel — auto from VERCEL_PROJECT_PRODUCTION_URL / VERCEL_URL)
# Enable "System Environment Variables" in Vercel project settings first.
# NEXT_PUBLIC_SITE_URL=https://jame-street.vercel.app

# Optional: Express backend URL for local dev (not needed for Vercel)
NEXT_PUBLIC_API_BASE=http://localhost:4000

# Python quant engine (Quant Lab) — server-side proxy only
QUANT_SERVICE_URL=http://localhost:8000

# Massive.com (https://massive.com/) — primary REST quotes (Polygon-compatible API)
MASSIVE_API_KEY=your-massive-api-key
# Optional S3 flat-file access key id (bulk downloads)
MASSIVE_ACCESS_KEY_ID=

# Finnhub (https://finnhub.io/) — server-side REST only (never use NEXT_PUBLIC_ for API keys)
FINNHUB_API_KEY=your-finnhub-api-key

# Optional: Screener.in session for private screens (India fundamentals via screener-india)
# SCREENER_IN_SESSION=sessionid=your-session-id

# Alpha Vantage — last-resort fallback only
ALPHAVANTAGE_API_KEY=your-alpha-vantage-api-key
